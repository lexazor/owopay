generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  fullName     String
  username     String       @unique
  whatsapp     String
  email        String       @unique
  password     String
  pin          String?
  isPinSet     Boolean      @default(false)
  pinAttempts  Int          @default(0)
  pinLockedAt  DateTime?
  balance      Decimal      @default(0) @db.Decimal(18, 2)
  role         Role         @default(USER)
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  transactions Transaction[]
  deposits     Deposit[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  logo      String
  badge     String?
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  providers Provider[]
}

model Provider {
  id          String    @id @default(cuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  logo        String
  description String?   @db.Text
  isActive    Boolean   @default(true)
  formFields  Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name         String
  nominal      Decimal       @db.Decimal(18, 2)
  price        Decimal       @db.Decimal(18, 2)
  badge        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model PaymentMethod {
  id              String    @id @default(cuid())
  name            String
  logo            String
  accountNumber   String
  accountName     String
  minAmount       Decimal   @db.Decimal(18, 2)
  maxAmount       Decimal   @db.Decimal(18, 2)
  uniqueCode      Boolean   @default(true)
  uniqueMin       Int       @default(100)
  uniqueMax       Int       @default(999)
  expiredMinutes  Int       @default(30)
  instructions    String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deposits        Deposit[]
}

model Transaction {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerData Json
  amount       Decimal   @db.Decimal(18, 2)
  status       TxStatus  @default(PENDING)
  note         String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Deposit {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  invoiceNumber   String        @unique
  amount          Decimal       @db.Decimal(18, 2)
  uniqueCode      Int
  totalAmount     Decimal       @db.Decimal(18, 2)
  proofImage      String?
  status          DepositStatus @default(PENDING)
  expiredAt       DateTime
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Banner {
  id        String  @id @default(cuid())
  image     String
  url       String?
  order     Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DepositStatus {
  PENDING
  WAITING_VERIFICATION
  SUCCESS
  FAILED
  EXPIRED
}
